# linker script for 16-bit real mode kernel
name kernel.bin               # Name of the output file
output raw                    # Output as a raw binary (no headers)
option NODEFAULTLIBS          # Do not link any standard libraries
option START=_cstart_         # The entry point of our program
file startup.obj              # MUST be first to ensure startup code comes first
file kernel.obj               # The compiled C kernel
order                         # Specify the order of segments in the final binary
    clname _TEXT              # The code segment comes first
    clname _DATA              # The data segment follows